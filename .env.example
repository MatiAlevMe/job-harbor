# Gemini API key (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini model (default: gemini-2.5-flash — still on free tier in 2026)
# Available free models: gemini-2.5-flash, gemini-3.1-flash-lite, gemini-3-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional: path to guia-laboral repo (default: ../guia-laboral)
GUIA_LABORAL_PATH=../guia-laboral

# Optional: Jooble API key (free: https://jooble.org/api/about)
JOOBLE_API_KEY=

# Optional: Ollama configuration (alternative to Gemini)
# phi4-mini recommended — lightweight, local, no API costs
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
